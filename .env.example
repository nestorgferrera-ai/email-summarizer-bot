# ============================================================
# BOT DE ALBARANES DE LAVANDERÍA — Variables de entorno
# ============================================================

# Token del bot de Telegram para ALBARANES (recepción de ropa de Selava)
LAUNDRY_TELEGRAM_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la Google Sheet donde se guardan los albaranes (recepción)
# (el ID está en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ============================================================
# BOT DE ENVÍO DIARIO — Variables de entorno adicionales
# ============================================================

# Token del bot de Telegram para ENVÍO DIARIO (ropa enviada a Selava)
# Debe ser un bot DIFERENTE al de albaranes (crear en @BotFather)
DAILY_TELEGRAM_TOKEN=0987654321:BBxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la Google Sheet del envío diario (hoja diferente a la de albaranes)
DAILY_SHEET_ID=2CyiNWt1YSB6oGNLvCcCaAkhnVrqumcmt85PhWgF3vnt

# Nombre de la pestaña dentro del sheet de envío diario (por defecto: "Envío Diario")
DAILY_SHEET_TAB=Envío Diario

# ID del Google Sheet donde se escribe el albarán final por período
# Si no se especifica, se usa el mismo que DAILY_SHEET_ID
ALBARAN_SHEET_ID=2CyiNWt1YSB6oGNLvCcCaAkhnVrqumcmt85PhWgF3vnt

# Nombre de la pestaña del albarán final (por defecto: "Albaran Entrega Selava")
ALBARAN_SHEET_TAB=Albaran Entrega Selava

# URL pública del bot de envío diario (en Render.com)
# El webhook se registra en: DAILY_APP_URL/daily-webhook
DAILY_APP_URL=https://daily-laundry-bot.onrender.com

# Puerto del bot de envío diario
DAILY_PORT=3002

# ============================================================
# VARIABLES COMPARTIDAS
# ============================================================

# Credenciales de la cuenta de servicio de Google (JSON completo en una sola línea)
# La misma cuenta de servicio puede acceder a ambos Google Sheets
# Ver instrucciones en README para obtenerlas
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"bot@proyecto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Chat IDs de Telegram autorizados a usar los bots (separados por coma)
# Déjalo vacío para permitir a cualquiera (no recomendado)
# Para obtener tu chat_id: escribe al bot y visita https://api.telegram.org/botTU_TOKEN/getUpdates
ALLOWED_CHAT_IDS=1771192684,987654321

# URL pública del servidor principal de albaranes
APP_URL=https://laundry-bot.onrender.com

# Puerto del bot de albaranes (Render lo asigna automáticamente)
PORT=3001
