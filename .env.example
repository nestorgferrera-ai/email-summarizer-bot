# ============================================================
# BOT DE LAVANDERÍA — Variables de entorno
# Un solo bot con /nuevo (recepción), /diario (envío) y /resumen
# ============================================================

# Token del bot de Telegram (obtener de @BotFather)
LAUNDRY_TELEGRAM_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- HOJA DE ALBARANES DE RECEPCIÓN ----
# Ropa recibida DE Selava (/nuevo)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
# Nombre de la pestaña (por defecto: "Respuestas de formulario 1")
ALBARAN_SHEET_TAB=Respuestas de formulario 1

# ---- HOJA DE ENVÍOS DIARIOS ----
# Ropa enviada A Selava (/diario)
DAILY_SHEET_ID=2CyiNWt1YSB6oGNLvCcCaAkhnVrqumcmt85PhWgF3vnt
# Nombre de la pestaña (por defecto: "Envío Diario")
DAILY_SHEET_TAB=Envío Diario

# ---- HOJA DE RESUMEN POR PERÍODO ----
# Donde se vuelca el albarán de totales (/resumen)
# Si no se especifica, se usa el mismo sheet que DAILY_SHEET_ID
RESUMEN_SHEET_ID=2CyiNWt1YSB6oGNLvCcCaAkhnVrqumcmt85PhWgF3vnt
# Nombre de la pestaña (por defecto: "Albaran Entrega Selava")
RESUMEN_SHEET_TAB=Albaran Entrega Selava

# ---- GOOGLE CREDENTIALS ----
# Credenciales de la cuenta de servicio de Google (JSON completo en una sola línea)
# La misma cuenta de servicio accede a todos los sheets
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"bot@proyecto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ---- EMAILS PARA EL RESUMEN ----
# Destinatarios del albarán por email (separados por coma)
# Para pruebas: solo el correo propio. Producción: añadir los otros dos.
RESUMEN_EMAIL_TO=tu-correo@ionos.es
# RESUMEN_EMAIL_TO=tu-correo@ionos.es,administracion@selava.es,alicia-macias@clinicabandama.com

# ---- ACCESO Y DESPLIEGUE ----
# Chat IDs de Telegram autorizados (separados por coma, vacío = todos)
ALLOWED_CHAT_IDS=1771192684,987654321

# URL pública del servidor (para registrar el webhook de Telegram)
APP_URL=https://tu-bot.onrender.com

# Puerto (Render lo asigna automáticamente)
PORT=3001
